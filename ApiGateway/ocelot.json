{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/pricing",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing",
      "UpstreamHttpMethod": [ "GET" ],
      "FileCacheOptions": {
        "TtlSeconds": 15
      },
      "RateLimitOptions": {
        "EnableRateLimiting": false,
        "Period": "1s",
        "Limit": 1
      }
    },
    {
      "DownstreamPathTemplate": "/api/pricing/{id}",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing/{id}",
      "UpstreamHttpMethod": [ "GET" ],
      "FileCacheOptions": {
        "TtlSeconds": 15
      },
      "RateLimitOptions": {
        "EnableRateLimiting": false,
        "Period": "1s",
        "Limit": 1
      }
    },
    {
      "DownstreamPathTemplate": "/api/pricing",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing",
      "UpstreamHttpMethod": [ "POST" ],
      "RateLimitOptions": {
        "EnableRateLimiting": false,
        "Period": "1s",
        "Limit": 1
      }
    },
    {
      "DownstreamPathTemplate": "/api/pricing/{id}",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing/{id}",
      "UpstreamHttpMethod": [ "PUT" ],
      "RateLimitOptions": {
        "EnableRateLimiting": false,
        "Period": "1s",
        "Limit": 1
      }
    },
    {
      "DownstreamPathTemplate": "/api/pricing/{id}",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing/{id}",
      "UpstreamHttpMethod": [ "DELETE" ],
      "RateLimitOptions": {
        "EnableRateLimiting": false,
        "Period": "1s",
        "Limit": 1
      }
    },
    {
      "DownstreamPathTemplate": "/api/policy",
      "DownstreamScheme": "http",
      "ServiceName": "POLICYSERVICE",
      "UpstreamPathTemplate": "/policy",
      "UpstreamHttpMethod": [ "GET" ],
      "FileCacheOptions": {
        "TtlSeconds": 15
      },
      "RateLimitOptions": {
        "EnableRateLimiting": false,
        "Period": "1s",
        "Limit": 1
      }
    }
  ],

  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5050",

    "ServiceDiscoveryProvider": {
      "Type": "Eureka",
      "Host": "eureka",
      "Port": 8761
    },

    "RateLimitOptions": {
      "ClientIdHeader": "ClientId",
      "QuotaExceededMessage": "Too many requests",
      "HttpStatusCode": 429,
      "DisableRateLimitHeaders": false
    }
  }
}